# Copy this file to .env and fill in values for local development.
# In Vercel, add each of these under Settings -> Environment Variables instead.

# --- Required for full functionality -----------------------------------
DATABASE_URL=
JWT_SECRET=
GEMINI_API_KEY=

# --- Optional — features gracefully degrade if these are unset ----------
GOOGLE_MAPS_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
ALLOWED_ORIGIN=

# Shared secret required to self-register a 'staff' account via
# /api/auth/signup. Leave unset to disable staff self-signup entirely
# (recommended default — provision staff accounts another way instead).
STAFF_SIGNUP_CODE=

# --- Optional — Neon Auth (Stack Auth), only if you swap in your own code ---
STACK_PROJECT_ID=
STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

NODE_ENV=development
